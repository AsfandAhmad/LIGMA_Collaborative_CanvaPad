{
  "name": "ligma-backend",
  "version": "1.0.0",
  "description": "Collaborative canvas backend with event sourcing and RBAC",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --testPathPatterns='src/ws/__tests__' --forceExit",
    "test:auth": "node src/ws/__tests__/yjsServer.test.js",
    "test:presence": "node src/ws/__tests__/presence.test.js",
    "test:cursor": "node src/ws/__tests__/wsServer.cursor.test.js",
    "test:events": "npm test",
    "prisma:generate": "prisma generate --schema=src/db/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/db/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/db/schema.prisma"
  },
  "keywords": [
    "websocket",
    "event-sourcing",
    "rbac",
    "collaborative"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "ws": "^8.18.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0"
  }
}
